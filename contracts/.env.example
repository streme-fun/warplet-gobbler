# Base mainnet RPC (forge script --rpc-url; or use named endpoint: --rpc-url $BASE_RPC_URL)
BASE_RPC_URL=

# Deployer key — hex with or without 0x (NEVER commit real keys). Set **exactly one**:
PRIVATE_KEY=
# DEPLOYER_PRIVATE_KEY=

# Basescan API key for `forge script --verify`
BASESCAN_API_KEY=

# ---------------------------------------------------------------------------
# DeployFeeHandler.s.sol — all required (no script defaults). Use 0x0 for REBALANCER to skip role.
# ---------------------------------------------------------------------------
WETH_ADDRESS=0x4200000000000000000000000000000000000006
STREME_TOKEN_ADDRESS=
LP_FACTORY_V4_ADDRESS=
AUCTION_ADDRESS=
STREME_ZAP_ADDRESS=
TARGET_DURATION_SECONDS=
ADMIN_ADDRESS=
REBALANCER_ADDRESS=

# ---------------------------------------------------------------------------
# script/DeployFeeHandlerAndDutchAuction.s.sol — FeeHandler + DutchAuction + wire
#     (also needs WETH/STREME/LP_FACTORY/ZAP/TARGET_DURATION/ADMIN entries above;
#      DutchAuction nft reserve address is listed under DeployDutchAuction below.)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# DeployAuctionSell.s.sol — all required (no script defaults). Also deploys GobbledWarplets.
# Bid token often matches STREME_TOKEN_ADDRESS.
# forge script script/DeployAuctionSell.s.sol:DeployAuctionSell --rpc-url base --broadcast --verify -vvv
# ---------------------------------------------------------------------------
AUCTION_SELL_ADDRESS=
WARPLETS_NFT_ADDRESS=
AUCTION_SELL_BID_TOKEN_ADDRESS=
AUCTION_SELL_PROCEEDS_RECIPIENT=
AUCTION_RESERVE_PRICE_WEI=
AUCTION_SELL_OWNER=
GOBBLED_WARPLETS_NAME=
GOBBLED_WARPLETS_SYMBOL=
# Optional; defaults to deployer — signer key for GobbledWarplets mint EIP-712.
GOBBLED_WARPLETS_TOKEN_URI_SETTER=
AUCTION_TIME_BUFFER_SECONDS=
AUCTION_MIN_BID_INCREMENT_PERCENT=
AUCTION_DURATION_SECONDS=
# Omit or zero for ERC20 bids only; set to StremeZapUniversal when using ETH `AuctionSell.bid`.
AUCTION_SELL_STREME_ZAP=
FINAL_NFT_RESERVE_OWNER=
FINAL_GOBBLED_WARPLETS_OWNER=

# ---------------------------------------------------------------------------
# script/DeployWarpletGobblerFull.s.sol — full stack (NFTReserve + Gobbled + AuctionSell wired + FeeHandler +
# Dutch V1/V2 + optional GobbleSniper); see script header NatSpec.
# forge script script/DeployWarpletGobblerFull.s.sol:DeployWarpletGobblerFull --rpc-url base --broadcast --verify -vvv
# Uses all DeployFeeHandler + DeployAuctionSell env above, plus DeployDutchAuction payment line + optional flags below.
DUTCH_AUCTION_FLAVOR=v2
DEPLOY_GOBBLE_SNIPER=0
POOL_MANAGER_ADDRESS=
SEAPORT_ADDRESS=
SNIPER_POOL_FEE=
SNIPER_POOL_TICK_SPACING=
SNIPER_POOL_HOOKS=
SNIPER_PROFIT_RECIPIENT=

# ---------------------------------------------------------------------------
# DeployDutchAuction.s.sol — all required; nft reserve = NFTReserve address (queue custody).
# forge script script/DeployDutchAuction.s.sol:DeployDutchAuction --rpc-url base --broadcast --verify -vvv
# After deploy: FeeHandler.setAuction(newDutchAuction) then FeeHandler.startStream() (admin).
# ---------------------------------------------------------------------------
DUTCH_AUCTION_PAYMENT_TOKEN_ADDRESS=
DUTCH_AUCTION_NFT_RESERVE_ADDRESS=
FEE_HANDLER_ADDRESS=

# MigrateToNewDutchAuction.s.sol — same vars as DeployDutchAuction + one broadcast: setAuction + startStream.
# forge script script/MigrateToNewDutchAuction.s.sol:MigrateToNewDutchAuction --rpc-url base --broadcast --verify -vvv

# FeeHandlerStartStream.s.sol — admin only; after funding handler with Streme (no verify).
# forge script script/FeeHandlerStartStream.s.sol:FeeHandlerStartStream --rpc-url base --broadcast -vvv

# AuctionSellUnpause.s.sol — owner only (no verify).
# forge script script/AuctionSellUnpause.s.sol:AuctionSellUnpause --rpc-url base --broadcast -vvv

# ---------------------------------------------------------------------------
# DeployGobbledWarplets.s.sol — deploy receipt collection only (needs existing NFTReserve).
# Reuses GOBBLED_WARPLETS_NAME, GOBBLED_WARPLETS_SYMBOL, GOBBLED_WARPLETS_TOKEN_URI_SETTER from DeployAuctionSell section.
# ---------------------------------------------------------------------------
GOBBLED_WARPLETS_RESERVE=

# ---------------------------------------------------------------------------
# ScanWarpletTokenIds.s.sol / web/scripts/scan-warplet-token-ids.mjs — all required; no defaults in scripts.
# Also requires WARPLETS_NFT_ADDRESS (see DeployAuctionSell section above).
# ---------------------------------------------------------------------------
SCAN_LEGACY_MAX_EXCLUSIVE=
SCAN_GOBBLED_MAX_EXCLUSIVE=
SCAN_MULTICALL_BATCH=

# ---------------------------------------------------------------------------
# FeeHandler fork tests (`forge test --match-path test/fork/FeeHandlerFork.t.sol`)
# ---------------------------------------------------------------------------
FEE_HANDLER_FORK_STREME=
FEE_HANDLER_FORK_BLOCK=
FEE_HANDLER_FORK_CASH=
FEE_HANDLER_FORK_LP_FACTORY=
FEE_HANDLER_FORK_STREME_ZAP=
