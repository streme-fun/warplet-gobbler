# Base mainnet RPC (forge script --rpc-url; or use named endpoint: --rpc-url $BASE_RPC_URL)
BASE_RPC_URL=

# Deployer key — hex string, with or without 0x (NEVER commit real keys)
PRIVATE_KEY=
# Alternate name supported by scripts:
# DEPLOYER_PRIVATE_KEY=

# Basescan API key for `forge script --verify`
BASESCAN_API_KEY=

# ---------------------------------------------------------------------------
# DeployFeeHandler.s.sol
# ---------------------------------------------------------------------------
WETH_ADDRESS=0x4200000000000000000000000000000000000006
STREME_TOKEN_ADDRESS=
LP_FACTORY_V4_ADDRESS=
AUCTION_ADDRESS=
STREME_ZAP_ADDRESS=
# Flow targeting: streme balance / TARGET_DURATION_SECONDS (seconds only; not "7 days")
TARGET_DURATION_SECONDS=604800
ADMIN_ADDRESS=
# Optional — omit or set to zero address to skip REBALANCER_ROLE
REBALANCER_ADDRESS=

# ---------------------------------------------------------------------------
# DeployAuctionSell.s.sol (also deploys GobbledWarplets)
# ---------------------------------------------------------------------------
WARPLETS_NFT_ADDRESS=
# Optional — defaults to STREME_TOKEN_ADDRESS (same token as gobbler / FeeHandler stream)
# AUCTION_SELL_BID_TOKEN_ADDRESS=
AUCTION_SELL_PROCEEDS_RECIPIENT=
# Reserve price in bid token wei (required)
AUCTION_RESERVE_PRICE_WEI=
# Optional — defaults to deployer
AUCTION_SELL_OWNER=
GOBBLED_WARPLETS_NAME=Gobbled Warplets
GOBBLED_WARPLETS_SYMBOL=GOBBLED
AUCTION_TIME_BUFFER_SECONDS=300
AUCTION_MIN_BID_INCREMENT_PERCENT=10
AUCTION_DURATION_SECONDS=86400

# ---------------------------------------------------------------------------
# FeeHandler fork tests (`forge test --match-path test/fork/FeeHandlerFork.t.sol`)
# ---------------------------------------------------------------------------
FEE_HANDLER_FORK_STREME=
FEE_HANDLER_FORK_BLOCK=
FEE_HANDLER_FORK_CASH=
FEE_HANDLER_FORK_LP_FACTORY=
FEE_HANDLER_FORK_STREME_ZAP=
