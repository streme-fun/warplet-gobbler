# Base mainnet RPC for fork testing
BASE_RPC_URL=

# FeeHandler fork tests (`forge test --match-path test/fork/FeeHandlerFork.t.sol`)
# Required: Superfluid Super Token address on Base (same token FeeHandler streams as `stremeToken`).
FEE_HANDLER_FORK_STREME=
# Optional: pin block (default = latest at fork creation)
FEE_HANDLER_FORK_BLOCK=
# Optional: defaults to Base USDC; Streme LPFactory / Zap when exercising swap+claim
FEE_HANDLER_FORK_CASH=
FEE_HANDLER_FORK_LP_FACTORY=
FEE_HANDLER_FORK_STREME_ZAP=

# Basescan API key for verification
BASESCAN_API_KEY=

# Deployer private key (NEVER commit this)
DEPLOYER_PRIVATE_KEY=
