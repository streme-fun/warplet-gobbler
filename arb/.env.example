# ─── RPC ───────────────────────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
# Optional: private RPC for tx submission (Flashbots, Blocknative, etc.)
# BASE_PRIVATE_RPC_URL=

# ─── Wallet ────────────────────────────────────────────────────────────
BOT_PRIVATE_KEY=0x...

# ─── Contract Addresses ───────────────────────────────────────────────
GOBBLE_SNIPER_ADDRESS=0x83a6F4a4F94CAFBAb0E6a4992EFEDc05C0774D5d
DUTCH_AUCTION_ADDRESS=0xD3598909A51Ac1227D8EFa240A216A61a43c8344
WARPLETS_ADDRESS=0x699727f9e01a822efdcf7333073f0461e5914b4e
WARPGOBB_TOKEN_ADDRESS=0x3042b035325393F3d72390C7E5d51F26fe1F0e61
WETH_ADDRESS=0x4200000000000000000000000000000000000006
POOL_MANAGER_ADDRESS=0x498581ff718922c3f8e6a244956af099b2652b2b
SEAPORT_ADDRESS=0x0000000000000068F116a894984e2DB1123eB395

# ─── Uniswap V4 Pool ──────────────────────────────────────────────────
# Pool key components (needed for swap encoding)
POOL_FEE=3000
POOL_TICK_SPACING=60
POOL_HOOKS=0x0000000000000000000000000000000000000000

# ─── OpenSea ───────────────────────────────────────────────────────────
OPENSEA_API_KEY=
WARPLETS_COLLECTION_SLUG=the-warplets-farcaster

# ─── Bot Config ────────────────────────────────────────────────────────
# Minimum net profit in ETH to execute (default: 0.001)
MIN_PROFIT_ETH=0.001
# Maximum ETH to spend on a single NFT (default: 0.5)
MAX_SPEND_ETH=0.5
# Poll interval in seconds (default: 15)
POLL_INTERVAL_SEC=15
# Slippage tolerance for swap (bps, default: 300 = 3%)
SWAP_SLIPPAGE_BPS=300
# Gas price buffer in bps (default: 12000 = 1.2x)
GAS_BUFFER_BPS=12000
# Dry run mode (default: false)
DRY_RUN=false
