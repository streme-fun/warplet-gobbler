{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "warplet-gobbler",
  "main": ".open-next/worker.mjs",
  "compatibility_date": "2026-03-29",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
