# WalletConnect project ID — get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# RPC for wagmi `http` in the browser — must allow CORS from your dev origin (e.g. localhost).
# Leave empty to use Base public RPC. Avoid endpoints that only work server-side (many Merkle URLs block browsers).
# Also used by server API routes (e.g. `/api/mint-gobbled-nft`) unless BASE_RPC_URL is set.
NEXT_PUBLIC_BASE_RPC_URL=
# Optional: Base JSON-RPC used only on the server (overrides default for mint pipeline chain reads).
BASE_RPC_URL=

# EIP-712 signer for `GobbledWarplets.rescueWarplet` metadata — must match contract `tokenURISetter`.
GOBBLED_TOKEN_URI_SETTER_PRIVATE_KEY=

# Ethereum mainnet (L1) — ENS resolution in `/api/bidder-profile` and ConnectKit. Optional; if unset, viem’s default public mainnet RPC is used.
NEXT_PUBLIC_ETH_RPC_URL=

# Contracts (Base)
NEXT_PUBLIC_DUTCH_AUCTION_ADDRESS=
NEXT_PUBLIC_AUCTION_SELL_ADDRESS=
NEXT_PUBLIC_GOBBLED_WARPLETS_ADDRESS=
# Previous stack — migration queue overlay + legacy bare rescue batch (optional until cutover)
NEXT_PUBLIC_AUCTION_SELL_LEGACY_ADDRESS=
NEXT_PUBLIC_GOBBLED_WARPLETS_LEGACY_ADDRESS=
NEXT_PUBLIC_AUCTION_SELL_LEGACY_DEPLOY_BLOCK=
NEXT_PUBLIC_STAKING_ADDRESS=
# Base block where AuctionSell was deployed. Used as the floor for targeted
# AuctionSettled lookups so old claimable wins do not hit a fixed lookback cliff.
NEXT_PUBLIC_AUCTION_SELL_DEPLOY_BLOCK=
# Optional — staking / protocol ERC-20 (legacy: NEXT_PUBLIC_STRAT_TOKEN_ADDRESS)
NEXT_PUBLIC_STAKING_TOKEN_ADDRESS=
NEXT_PUBLIC_WARPGOBB_TOKEN_ADDRESS=
NEXT_PUBLIC_WETH_TOKEN_ADDRESS=
# The Warplets (WPLT) on Base — required for wallet picker
NEXT_PUBLIC_WARPLETS_ADDRESS=0x699727f9e01a822efdcf7333073f0461e5914b4e
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=
NEXT_PUBLIC_PAYMENT_TOKEN_SYMBOL=WARPGOBB
# Dev: append fake queue strip + local skip-line animation (no tx). Omit or false in production.
NEXT_PUBLIC_SKIP_LINE_MOCK_FLAG=

# Auction / secondary-market bid label (defaults to NEXT_PUBLIC_PAYMENT_TOKEN_SYMBOL)
NEXT_PUBLIC_AUCTION_BID_TOKEN_SYMBOL=
NEXT_PUBLIC_WARPGOBB_WETH_POOL_ADDRESS=
NEXT_PUBLIC_UNISWAP_V4_STATE_VIEW_ADDRESS=0xa3c0c9b65bad0b08107aa264b0f3db444b867a71
# v4 pool id (bytes32). Same as NEXT_PUBLIC_WARPGOBB_WETH_POOL_ID if you use that name.
NEXT_PUBLIC_UNISWAP_V4_WARPGOBB_WETH_POOL_ID=
NEXT_PUBLIC_WETH_USDC_POOL_ADDRESS=

# Gobbled Warplet Image Pipeline
GEMINI_API_KEY=
warpletgobbler_READ_WRITE_TOKEN=
PINATA_JWT=
PINATA_GATEWAY_URL=

# Footer / links
# e.g. https://www.geckoterminal.com/base/pools/<pool-address>
NEXT_PUBLIC_GECKOTERMINAL_POOL_URL=
