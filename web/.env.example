# WalletConnect project ID — get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# RPC for wagmi `http` in the browser — must allow CORS from your dev origin (e.g. localhost).
# Leave empty to use Base public RPC. Avoid endpoints that only work server-side (many Merkle URLs block browsers).
NEXT_PUBLIC_BASE_RPC_URL=

# Contracts (Base)
NEXT_PUBLIC_DUTCH_AUCTION_ADDRESS=
NEXT_PUBLIC_AUCTION_SELL_ADDRESS=
NEXT_PUBLIC_STAKING_ADDRESS=
# Optional — staking / protocol ERC-20 (legacy: NEXT_PUBLIC_STRAT_TOKEN_ADDRESS)
NEXT_PUBLIC_STAKING_TOKEN_ADDRESS=
NEXT_PUBLIC_WARPGOBB_TOKEN_ADDRESS=
NEXT_PUBLIC_WETH_TOKEN_ADDRESS=
# The Warplets (WPLT) on Base — required for wallet picker
NEXT_PUBLIC_WARPLETS_ADDRESS=0x699727f9e01a822efdcf7333073f0461e5914b4e
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=
NEXT_PUBLIC_PAYMENT_TOKEN_SYMBOL=WARPGOBB
# Auction / secondary-market bid label (defaults to NEXT_PUBLIC_PAYMENT_TOKEN_SYMBOL)
NEXT_PUBLIC_AUCTION_BID_TOKEN_SYMBOL=
NEXT_PUBLIC_WARPGOBB_WETH_POOL_ADDRESS=
NEXT_PUBLIC_UNISWAP_V4_STATE_VIEW_ADDRESS=0xa3c0c9b65bad0b08107aa264b0f3db444b867a71
# v4 pool id (bytes32). Same as NEXT_PUBLIC_WARPGOBB_WETH_POOL_ID if you use that name.
NEXT_PUBLIC_UNISWAP_V4_WARPGOBB_WETH_POOL_ID=
NEXT_PUBLIC_WETH_USDC_POOL_ADDRESS=
