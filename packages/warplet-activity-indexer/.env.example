# --- Chain / Ponder ---
PONDER_RPC_URL_8453=https://mainnet.base.org
# Prefer a Postgres database in production (Coolify-managed Postgres is ideal).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/warplet_activity

# Set these to the deployed contract addresses.
PONDER_AUCTION_SELL_ADDRESS=0x0000000000000000000000000000000000000000
PONDER_DUTCH_AUCTION_ADDRESS=0x0000000000000000000000000000000000000000

# Use a concrete deployment block if you want historical backfill.
# Use latest to begin from "now" and avoid backfill notifications.
PONDER_START_BLOCK=latest

# Optional HTTP / live indexing tuning.
PONDER_WS_URL_8453=

# --- Telegram routing ---
# Default route used when a per-event route is not provided.
TELEGRAM_DEFAULT_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
# Optional forum topic/thread id in Telegram groups.
TELEGRAM_DEFAULT_MESSAGE_THREAD_ID=
TELEGRAM_DEFAULT_SILENT=false

# Backwards-compatible aliases for the default route also work:
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_MESSAGE_THREAD_ID=
# TELEGRAM_SILENT=false

# Optional per-event overrides. You can route each type to a different chat/topic/bot.
TELEGRAM_BID_PLACED_CHAT_ID=
TELEGRAM_BID_PLACED_MESSAGE_THREAD_ID=
TELEGRAM_WARPLET_GOBBLED_CHAT_ID=
TELEGRAM_WARPLET_GOBBLED_MESSAGE_THREAD_ID=
TELEGRAM_AUCTION_SETTLED_CHAT_ID=
TELEGRAM_AUCTION_SETTLED_MESSAGE_THREAD_ID=
TELEGRAM_NEW_USER_INTERACTION_CHAT_ID=
TELEGRAM_NEW_USER_INTERACTION_MESSAGE_THREAD_ID=

# Optional per-event bot token overrides if you ever want separate bots too.
TELEGRAM_BID_PLACED_BOT_TOKEN=
TELEGRAM_WARPLET_GOBBLED_BOT_TOKEN=
TELEGRAM_AUCTION_SETTLED_BOT_TOKEN=
TELEGRAM_NEW_USER_INTERACTION_BOT_TOKEN=

# --- Neynar enrichment (optional) ---
NEYNAR_API_KEY=
# Optional client ID header for Neynar.
NEYNAR_CLIENT_ID=

# --- Notification behavior ---
# If true, notify on all indexed events including backfill.
INDEXER_NOTIFY_ON_BACKFILL=true
# If backfill notifications are disabled, you can start notifying from a specific block.
# Useful when indexing history into the DB first, then enabling live notifs later.
INDEXER_NOTIFY_FROM_BLOCK=
