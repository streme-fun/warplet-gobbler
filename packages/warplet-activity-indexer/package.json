{
  "name": "warplet-activity-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ponder indexer for Warplet Gobbler activity with Telegram notifications and optional Neynar enrichment.",
  "scripts": {
    "dev": "pnpm --filter telegram-notifier build && ponder dev",
    "start": "pnpm --filter telegram-notifier build && ponder start",
    "codegen": "ponder codegen",
    "typecheck": "pnpm --filter telegram-notifier build && tsc -p tsconfig.json --noEmit",
    "build": "pnpm --filter telegram-notifier build && tsc -p tsconfig.json",
    "clean": "rm -rf dist .ponder"
  },
  "dependencies": {
    "ponder": "^0.12.0",
    "telegram-notifier": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
