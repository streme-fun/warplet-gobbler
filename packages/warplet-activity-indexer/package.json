{
  "name": "warplet-activity-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ponder indexer for Warplet Gobbler activity with Telegram notifications and optional Neynar enrichment.",
  "scripts": {
    "dev": "ponder dev",
    "start": "ponder start",
